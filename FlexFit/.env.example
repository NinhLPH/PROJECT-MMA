# Full API base URL used by the Expo app.
# Android emulator: use http://10.0.2.2:5000/api.
# Physical Android device over USB: keep localhost and run
# `adb reverse tcp:5000 tcp:5000` after connecting the device.
# Physical device over Wi-Fi: use the development machine's current LAN IP.
EXPO_PUBLIC_API_URL=http://localhost:5000/api
